# Polymarket Weather Bot — Konfigurace
# Zkopíruj tento soubor jako .env a vyplň hodnoty:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# METEOBLUE (volitelné — EU předpovědi)
# ---------------------------------------------------------------------------
# Bez Meteoblue API klíče se EU města obslouží přes YR (yr.no) — zdarma.
# Meteoblue nabízí přesnější data ale vyžaduje registraci.
# Registrace: https://www.meteoblue.com/en/weather-api
# METEOBLUE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# Weather Providers — USA
# ---------------------------------------------------------------------------
# Výchozí: NOAA (zdarma, bez klíče, přesné)
# USA_WEATHER_PROVIDER=noaa

# Open-Meteo jako záloha při výpadku NOAA:
# USA_WEATHER_PROVIDER=noaa,openmeteo

# Per-město override:
# WEATHER_PROVIDER_NEW_YORK=openmeteo
# WEATHER_PROVIDER_DALLAS=noaa,openmeteo

# ---------------------------------------------------------------------------
# Weather Providers — EU
# ---------------------------------------------------------------------------
# Výchozí: YR (yr.no / MET Norway, zdarma, bez klíče)
# EU_WEATHER_PROVIDER=yr

# YR + Open-Meteo ensemble:
# EU_WEATHER_PROVIDER=yr,openmeteo

# Meteoblue jako primár (vyžaduje API klíč):
# EU_WEATHER_PROVIDER=meteoblue

# ---------------------------------------------------------------------------
# Ensemble forecast (doporučeno — průměr z více zdrojů)
# ---------------------------------------------------------------------------
# Pro US města:
# ENSEMBLE_PROVIDERS=noaa,openmeteo

# Pro EU města (oba zdarma):
# ENSEMBLE_PROVIDERS=yr,openmeteo

# Globálně (jedno nastavení, meteoblue jen pokud máš klíč):
# ENSEMBLE_PROVIDERS=noaa,yr,openmeteo

# ---------------------------------------------------------------------------
# Portfolio
# ---------------------------------------------------------------------------
# Počáteční balance (výchozí: $100)
# INITIAL_BALANCE=100.0

# Velikost jedné pozice (výchozí: $4)
# POSITION_SIZE=4.0

# ---------------------------------------------------------------------------
# Edge filter (výchozí hodnoty jsou vyvážené pro reálné trhy)
# ---------------------------------------------------------------------------
# Minimální edge pro vstup = naše P(výhry) − tržní cena YES (výchozí: 5 % = 0.05)
# Příklad: forecast=65°F, "exceed 65°F" trh za 42% → naše P=50% → edge=8% → BUY
# Nižší = více obchodů, vyšší = selektivnější
# MIN_EDGE=0.03

# Nejistota předpovědi — σ normálního rozdělení
# FORECAST_SIGMA_F=3.0    # ±3°F (NOAA 24h forecast je typicky ±3-4°F)
# FORECAST_SIGMA_C=1.5    # ±1.5°C

# Použít ensemble std_dev jako sigma? (výchozí: true)
# EDGE_ENSEMBLE_SIGMA=true

# ---------------------------------------------------------------------------
# Exit strategie
# ---------------------------------------------------------------------------
# Profit-take threshold (výchozí: 0.50 = prodej při ceně ≥ 50%)
# PROFIT_TAKE_THRESHOLD=0.50

# Stop-loss (výchozí: 0.60 = prodej při ztrátě ≥ 60% entry hodnoty)
# Příklad: koupeno za 0.35 → stop pokud cena klesne pod 0.14
# Nastavení 0 = vypnuto
# STOP_LOSS_THRESHOLD=0.60

# ---------------------------------------------------------------------------
# Forecast recheck (každé 3 hodiny)
# ---------------------------------------------------------------------------
# Min. rozdíl předpovědi pro označení jako "diverged"
# FORECAST_DIVERGE_THRESHOLD_F=5.0    # °F
# FORECAST_DIVERGE_THRESHOLD_C=2.5    # °C

# P&L zisk vyžadovaný před prodejem diverged pozice (výchozí: 50%)
# DIVERGED_PROFIT_TAKE_PCT=0.50

# ---------------------------------------------------------------------------
# Systém
# ---------------------------------------------------------------------------
# Adresář pro data (výchozí: ./data)
# BOT_DATA_DIR=/path/to/data

# Minimální pohyb ceny pro zápis do logu
# PRICE_CHANGE_LOG_MIN=0.005

# Nákupní okno — kolik hodin před půlnocí místního času se nakupuje
# Výchozí: 4 → nákup probíhá v 20:00–23:59 lokálně pro každé město
# BUY_HOURS_BEFORE=4