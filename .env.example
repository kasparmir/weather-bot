# Polymarket Weather Bot — Konfigurace
# Zkopíruj tento soubor jako .env a vyplň hodnoty:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# POVINNÉ
# ---------------------------------------------------------------------------

# Meteoblue API klíč (pro EU města: London, Paris, Madrid, Warsaw)
# Registrace: https://www.meteoblue.com/en/weather-api
# Cena: Free tier (1000 requests/měsíc) nebo placené plány
METEOBLUE_API_KEY=your_meteoblue_api_key_here

# ---------------------------------------------------------------------------
# VOLITELNÉ — Přepisy výchozích hodnot
# ---------------------------------------------------------------------------

# Adresář pro ukládání dat (výchozí: ./data)
# BOT_DATA_DIR=/path/to/custom/data/dir

# ---------------------------------------------------------------------------
# Ensemble & Edge filter
# ---------------------------------------------------------------------------
# Ensemble mód — průměr z více providerů (doporučeno pro vyšší přesnost)
# Prázdné = vypnuto, použije se standardní USA_WEATHER_PROVIDER chain
# ENSEMBLE_PROVIDERS=noaa,openmeteo
# ENSEMBLE_PROVIDERS=noaa,openmeteo,wunderground

# Minimální edge pro vstup do pozice (výchozí: 8 % = 0.08)
# Edge = naše_pravděpodobnost_výhry − tržní_cena_YES
# Příklad: forecast=65°F, kontrakt "exceed 65°F", market YES=40%
#          Naše P(YES) ≈ 50% → edge = 50%-40% = +10% > 8% → vstoupit
# MIN_EDGE=0.08

# Nejistota předpovědi — sigma normálního rozdělení (výchozí: ±3°F / ±1.5°C)
# Větší sigma = konzervativnější vstup (vyžaduje větší edge)
# FORECAST_SIGMA_F=3.0
# FORECAST_SIGMA_C=1.5

# Použít std_dev z ensemble jako sigma? (výchozí: true)
# Pokud ensemble zdroje nesouhlasí (velký rozptyl), sigma se zvýší
# EDGE_ENSEMBLE_SIGMA=true

# ---------------------------------------------------------------------------
# Profit-take threshold (výchozí: 0.50 = 50%)
# PROFIT_TAKE_THRESHOLD=0.50

# Stop-loss threshold (výchozí: 0.70 = 70% ztráta z entry price)
# Příklad: entry=0.40, limit=0.70 → prodej pokud cena klesne pod 0.40*(1-0.70)=0.12
# Nastavení 0 stop-loss vypne.
# STOP_LOSS_THRESHOLD=0.70

# Forecast recheck — min. rozdíl pro označení jako diverged
# FORECAST_DIVERGE_THRESHOLD_F=5.0   # °F (výchozí 5°F)
# FORECAST_DIVERGE_THRESHOLD_C=2.5   # °C (výchozí 2.5°C)
# Cílový P&L zisk pro diverged pozice před prodejem (výchozí: 50 % = 0.50)
# DIVERGED_PROFIT_TAKE_PCT=0.50

# Velikost pozice v USDC (výchozí: 10.0)
# POSITION_SIZE=10.0

# Minimální změna ceny pro log záznam (výchozí: 0.005 = 0.5%)
# PRICE_CHANGE_LOG_MIN=0.005

# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# Weather Providers (USA města)
# ---------------------------------------------------------------------------
# Výchozí provider pro všechna US města: NOAA (doporučeno)
# USA_WEATHER_PROVIDER=noaa

# Přepnout všechna US města na Weather Underground scraper:
# USA_WEATHER_PROVIDER=wunderground

# NOAA primárně, WU jako fallback, Open-Meteo jako záloha:
# USA_WEATHER_PROVIDER=noaa,wunderground,openmeteo

# Open-Meteo (zdarma, bez API klíče, spolehlivé):
# USA_WEATHER_PROVIDER=openmeteo

# WU selže → automaticky přejde na Open-Meteo:
# USA_WEATHER_PROVIDER=wunderground,openmeteo

# Per-město override (přepíše globální nastavení):
# WEATHER_PROVIDER_NEW_YORK=wunderground
# WEATHER_PROVIDER_DALLAS=noaa,wunderground
# WEATHER_PROVIDER_CHICAGO=wunderground

# ---------------------------------------------------------------------------
# NOAA API
# ---------------------------------------------------------------------------
# NOAA API nevyžaduje API klíč (veřejné, bezplatné)
# Dokumentace: https://www.weather.gov/documentation/services-web-api
# Žádné nastavení potřeba.

# ---------------------------------------------------------------------------
# Polymarket Gamma API
# ---------------------------------------------------------------------------
# Gamma API je plně veřejné, nevyžaduje autentizaci (read-only)
# Dokumentace: https://docs.polymarket.com
# Žádné nastavení potřeba.

# ---------------------------------------------------------------------------
# OpenClaw konfigurace
# ---------------------------------------------------------------------------
# Tyto hodnoty jsou používány v cron_setup.sh

# Python příkaz (výchozí: python3)
# PYTHON_CMD=python3

# OpenClaw session (výchozí: main)
# OPENCLAW_SESSION=main

# Notifikační kanál (např. telegram, discord) — prázdné = jen log
# NOTIFY_CHANNEL=telegram
# NOTIFY_TARGET=123456789  # Telegram chat ID