# Polymarket Weather Bot — Konfigurace
# Zkopíruj tento soubor jako .env a vyplň hodnoty:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# METEOBLUE (volitelné — extra EU zdroj)
# ---------------------------------------------------------------------------
# Bez klíče EU města obslouží YR + Open-Meteo + probabilistický ensemble — zdarma.
# Registrace: https://www.meteoblue.com/en/weather-api
# METEOBLUE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# Ensemble forecast
# ---------------------------------------------------------------------------
# Výchozí (bez nastavení): openmeteo_models,noaa,yr
#   openmeteo_models = 8 deterministických NWP modelů jedním requestem (ECMWF, GFS, ICON, ...)
#   noaa             = NOAA (US only, selže silently pro EU)
#   yr               = YR/MET Norway (EU, selže silently pro US)
# + automaticky: probabilistický ensemble z ensemble-api.open-meteo.com (50–143 členů)
#
# Vypnutí ensemble (použij standardní provider fallback):
# ENSEMBLE_PROVIDERS=off
#
# Vlastní sada (jen openmeteo modely, bez NOAA/YR):
# ENSEMBLE_PROVIDERS=openmeteo_models
#
# S Meteoblue (pokud máš klíč):
# ENSEMBLE_PROVIDERS=openmeteo_models,noaa,yr,meteoblue

# ---------------------------------------------------------------------------
# Weather Providers — fallback (používá se jen při ENSEMBLE_PROVIDERS=off)
# ---------------------------------------------------------------------------
# Per-město override (potlačí i ensemble):
# WEATHER_PROVIDER_NEW_YORK=openmeteo
# WEATHER_PROVIDER_LONDON=yr

# Regionální default při vypnutém ensemble:
# USA_WEATHER_PROVIDER=noaa
# EU_WEATHER_PROVIDER=yr

# ---------------------------------------------------------------------------
# Portfolio
# ---------------------------------------------------------------------------
# Počáteční balance (výchozí: $100)
# INITIAL_BALANCE=100.0

# Velikost jedné pozice v dolarech (výchozí: $4)
# POSITION_SIZE=4.0

# ---------------------------------------------------------------------------
# Edge filter
# ---------------------------------------------------------------------------
# Minimální edge pro vstup = naše P(výhry) − tržní cena YES
# Výchozí: 2.5 % — s probabilistickým ensemble je edge spolehlivější než dříve.
# Nižší = více obchodů, vyšší = selektivnější.
# MIN_EDGE=0.025

# Minimální P(YES) — zabrání lottery-ticket trhům, kde edge je pozitivní
# jen proto, že obě strany jsou tiny (např. naše 4 % vs tržní 1 %).
# Výchozí: 30 %
# MIN_PROBABILITY=0.30

# Nejistota předpovědi — σ normálního rozdělení (fallback bez probabilistického ensemble)
# Multi-model ensemble typicky dosahuje ±2°F / ±1.1°C — proto nižší výchozí hodnoty.
# FORECAST_SIGMA_F=2.0    # °F
# FORECAST_SIGMA_C=1.1    # °C

# Použít ensemble std_dev jako sigma? (výchozí: true — doporučeno)
# EDGE_ENSEMBLE_SIGMA=true

# ---------------------------------------------------------------------------
# Exit strategie
# ---------------------------------------------------------------------------
# Profit-take — splnění JEDNÉ podmínky spustí prodej:
#
#   A) YES cena >= PROFIT_TAKE_THRESHOLD a zároveň >= entry * 1.20  (výchozí: 0.50)
#      Guard *1.20 zabrání prodeji ihned po nákupu při volatilitě.
#      Nastavení 0 = podmínka vypnuta
# PROFIT_TAKE_THRESHOLD=0.50
#
#   B) Nerealizovaný P&L >= X dolarů  (výchozí: $0.50 = 12.5 % z $4 pozice)
#      Prodá jakmile vyděláš $0.50 bez ohledu na procenta.
#      Nastavení 0 = podmínka vypnuta
# PROFIT_TAKE_ABS=0.50
#
#   C) Nerealizovaný P&L >= X procent od entry  (výchozí: 50 % = $2 z $4 pozice)
#      Nastavení 0 = podmínka vypnuta
# PROFIT_TAKE_PCT=0.50

# Stop-loss (výchozí: 0.60 = prodej při ztrátě ≥ 60 % entry hodnoty)
# Příklad: koupeno za 0.35 → stop pokud cena klesne pod 0.14
# Nastavení 0 = vypnuto
# STOP_LOSS_THRESHOLD=0.60

# ---------------------------------------------------------------------------
# Forecast recheck (každé 3 hodiny)
# ---------------------------------------------------------------------------
# Min. rozdíl předpovědi od původního trade pro označení jako "diverged"
# FORECAST_DIVERGE_THRESHOLD_F=5.0    # °F
# FORECAST_DIVERGE_THRESHOLD_C=2.5    # °C

# P&L zisk vyžadovaný před prodejem diverged pozice (výchozí: 50 %)
# DIVERGED_PROFIT_TAKE_PCT=0.50

# ---------------------------------------------------------------------------
# Nákupní okno — timing
# ---------------------------------------------------------------------------
# Kolik hodin před půlnocí místního času se nakupuje T+1 (výchozí: 8).
# → výchozí okno: 16:00–23:59 lokálně pro každé město.
#
# Proč 8? ECMWF 12Z run je dostupný ~17–18 UTC (12–13 EST, 18–19 CET).
# Nákup v 16:00 lokálně zastihneme trh dřív, než ostatní bettors stihnou
# reagovat na nová data. Přesnost 00Z ensemblu (max 10h starého) je
# jen o ~0.3°F horší než 12Z → zanedbatelný rozdíl.
# BUY_HOURS_BEFORE=8

# --- T+2 lookahead nákupy ---
# Nakupovat i pro pozítří (T+2) když je ensemble sebejistý.
# Trhy pro T+2 jsou nejméně eficientní — casual bettors nemyslí tak dopředu.
# Vypnutí: LOOK_AHEAD_DAYS=1
# LOOK_AHEAD_DAYS=2

# Minimální edge pro T+2 nákupy (výchozí: 8 % — vyšší než T+1 kvůli větší nejistotě)
# LOOK_AHEAD_MIN_EDGE=0.08

# Maximální ensemble sigma pro T+2 nákup — jen „sure thing" situace
# (jasná horká vlna / studená fronta kde se modely shodují)
# LOOK_AHEAD_MAX_SIGMA_F=2.5    # °F
# LOOK_AHEAD_MAX_SIGMA_C=1.4    # °C

# ---------------------------------------------------------------------------
# Systém
# ---------------------------------------------------------------------------
# Adresář pro data (výchozí: ./data)
# BOT_DATA_DIR=/path/to/data

# Minimální pohyb ceny pro zápis do logu
# PRICE_CHANGE_LOG_MIN=0.005
