# Polymarket Weather Bot — Konfigurace
# Zkopíruj tento soubor jako .env a vyplň hodnoty:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# POVINNÉ
# ---------------------------------------------------------------------------

# Meteoblue API klíč (pro EU města: London, Paris, Madrid, Warsaw)
# Registrace: https://www.meteoblue.com/en/weather-api
# Cena: Free tier (1000 requests/měsíc) nebo placené plány
METEOBLUE_API_KEY=your_meteoblue_api_key_here

# ---------------------------------------------------------------------------
# VOLITELNÉ — Přepisy výchozích hodnot
# ---------------------------------------------------------------------------

# Adresář pro ukládání dat (výchozí: ./data)
# BOT_DATA_DIR=/path/to/custom/data/dir

# Profit-take threshold (výchozí: 0.50 = 50%)
# PROFIT_TAKE_THRESHOLD=0.50

# Stop-loss threshold (výchozí: 0.70 = 70% ztráta z entry price)
# Příklad: entry=0.40, limit=0.70 → prodej pokud cena klesne pod 0.40*(1-0.70)=0.12
# Nastavení 0 stop-loss vypne.
# STOP_LOSS_THRESHOLD=0.70

# Velikost pozice v USDC (výchozí: 10.0)
# POSITION_SIZE=10.0

# Minimální změna ceny pro log záznam (výchozí: 0.005 = 0.5%)
# PRICE_CHANGE_LOG_MIN=0.005

# ---------------------------------------------------------------------------
# NOAA API
# ---------------------------------------------------------------------------
# NOAA API nevyžaduje API klíč (veřejné, bezplatné)
# Dokumentace: https://www.weather.gov/documentation/services-web-api
# Žádné nastavení potřeba.

# ---------------------------------------------------------------------------
# Polymarket Gamma API
# ---------------------------------------------------------------------------
# Gamma API je plně veřejné, nevyžaduje autentizaci (read-only)
# Dokumentace: https://docs.polymarket.com
# Žádné nastavení potřeba.

# ---------------------------------------------------------------------------
# OpenClaw konfigurace
# ---------------------------------------------------------------------------
# Tyto hodnoty jsou používány v cron_setup.sh

# Python příkaz (výchozí: python3)
# PYTHON_CMD=python3

# OpenClaw session (výchozí: main)
# OPENCLAW_SESSION=main

# Notifikační kanál (např. telegram, discord) — prázdné = jen log
# NOTIFY_CHANNEL=telegram
# NOTIFY_TARGET=123456789  # Telegram chat ID